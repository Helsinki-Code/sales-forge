{
  "name": "@seoforge/worker",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node --env-file=../../.env --import tsx --watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@seoforge/agent-runtime": "*",
    "@seoforge/core": "*",
    "@seoforge/integrations": "*",
    "@seoforge/repo-runner": "*",
    "@seoforge/seo-geo": "*",
    "@supabase/supabase-js": "^2.56.1",
    "bullmq": "^5.58.0",
    "google-auth-library": "^10.9.0",
    "ioredis": "^5.8.1"
  },
  "devDependencies": {
    "@types/node": "^22.15.0",
    "tsx": "^4.20.0",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
