# Public web
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
PUBLIC_LAUNCH_ENABLED=false
LAUNCH_ALLOWLIST_EMAILS=

# Supabase / data plane
SUPABASE_SERVICE_ROLE_KEY=
DATABASE_URL=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres
REDIS_URL=redis://localhost:6379

# Encryption: base64-encoded 32-byte key
CREDENTIAL_ENCRYPTION_KEY=
API_TOKEN_PEPPER=
REVIEW_URL_SIGNING_SECRET=

# Gemini platform account
GEMINI_API_KEY=
GEMINI_FAST_MODEL=gemini-3.5-flash
GEMINI_REASONING_MODEL=gemini-3.1-pro-preview
GEMINI_IMAGE_MODEL=gemini-3.1-flash-image
GEMINI_TTS_MODEL=gemini-3.1-flash-tts-preview
GEMINI_VIDEO_MODEL=gemini-omni-flash-preview
GEMINI_LIVE_MODEL=gemini-3.1-flash-live-preview
GEMINI_INPUT_COST_PER_MILLION=0
GEMINI_OUTPUT_COST_PER_MILLION=0

# GitHub OAuth + GitHub App
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_APP_ID=
GITHUB_APP_SLUG=
GITHUB_APP_PRIVATE_KEY=
GITHUB_WEBHOOK_SECRET=

# Vercel integration
SEOFORGE_VERCEL_INTEGRATION_SLUG=seoforge
SEOFORGE_VERCEL_CLIENT_ID=
SEOFORGE_VERCEL_CLIENT_SECRET=
SEOFORGE_VERCEL_WEBHOOK_SECRET=

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/oauth/google/callback
PAGESPEED_API_KEY=

# Stripe Billing (API version 2026-02-25.clover)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_STARTER_PRICE_ID=
STRIPE_PRO_PRICE_ID=
STRIPE_AGENCY_PRICE_ID=

# Artifact storage (use gcs on Google Cloud; Cloud Run uses its service account)
STORAGE_PROVIDER=gcs
GCS_BUCKET=
GCS_PUBLIC_BASE_URL=

# Optional S3-compatible alternative
S3_ENDPOINT=
S3_REGION=auto
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_PUBLIC_BASE_URL=

# Runner
RUNNER_IMAGE=seoforge/repo-runner:local
RUNNER_WORK_ROOT=/tmp/seoforge-runs
RUNNER_URL=http://localhost:8080
RUNNER_SHARED_SECRET=
RUNNER_GOOGLE_AUTH=false

# Notifications
RESEND_API_KEY=
RESEND_FROM=alerts@seoforge.ai
